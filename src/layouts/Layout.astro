---
import "../styles/global.css"

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Meesterschap</title>
	</head>
	<body>
		<button class="theme-toggle" type="button" aria-label="wissel thema">☀️</button>
		<slot />
		<script>
			const themaButton = document.querySelector(".theme-toggle");
			const savedTheme = localStorage.getItem("theme");
			
			if (savedTheme === "dark") {
				document.body.classList.add("dark-theme");
				if(themaButton) themaButton.textContent = "🌙";
			}
			themaButton?.addEventListener("click", () => {
				document.body.classList.toggle("dark-theme");
				const isDark = document.body.classList.contains("dark-theme");
				localStorage.setItem("theme", isDark ? "dark" : "light");
				themaButton.textContent = isDark ? "🌙" : "☀️";
			});
			</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
