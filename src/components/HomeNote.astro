---
const { number, label, title, text, link, linkText, className } = Astro.props;
---

<article class={`card-note ${className}`}>
    <!-- <div class="note-content"> -->
    <span class="note-number">{number}</span>
    <p class="note-label">{label}</p>
    <h2>{title}</h2>
    <p>{text}</p>
    <a class="link-section" href={link}>{linkText}</a>
</article>

<style>
    .card-note {
        min-height: 250px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background-color: rgba(253, 241, 167, 0.681);
        padding: 1.5em;
        overflow: hidden;
        border-radius: 0.5em;
        border: 2px solid #020101;
        box-shadow: 8px 6px 0 #293603c1;
        gap: 0.4em;
        position: relative;
        background-image: url(../assets/brown-paper-texture-background.jpg);
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
    }
    .card-note h2 {
        margin: 0.5rem 0 1rem;
    }
    .card-note a {
        font-size: 15px;
        font-weight: 650;
        width: fit-content;
        padding: 0.65em 0.9em;
        text-decoration: none;
        color: #020101;
        background-color: rgb(253, 173, 25);
        border-radius: 0.2em;
        border: 2px solid #020101;
        box-shadow: 8px 6px 0;
    }
    .card-note .note-number {
        font-size: 5rem;
        font-weight: 900;
        opacity: 0.12;
        line-height: 1;
        color: #353906;
        position: absolute;
        right: 1rem;
        top: 0.5rem;
    }
    /* @media (min-width: 900px) {
        .card-note {
			min-height: 320px;
		}
		.card-note .note-leerdoelen {
			transform: rotate(-1deg);
			margin-top: 2rem;
		}
    }    */

</style>
