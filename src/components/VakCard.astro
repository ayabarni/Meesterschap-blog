---
type Props = {
    image: string;
    alt: string;
    title: string;
    subtitle: string;
    paragraphs: string [];
    learned?: string[];

};
const { image, alt, title, subtitle, paragraphs, learned } = Astro.props;
---
<article class="vak-card">
    <img src={image} alt={alt} class="vak-image" /> 
    <div class="vak-content">
        <h2>{title}</h2>
        <p class="vak-subtitle">{subtitle}</p>
        <div class="summary">
            {paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
            ))}
        </div>
        {learned && (
            <div class="info-box">
                <h3>Wat heb ik geleerd?</h3>
                <ul>
                    {learned.map((item) => (
                        <li>{item}</li>
                    ))}
                </ul>
            </div>


        )}

    </div>

</article>
<style>
	.vak-card {
		overflow: hidden;
		border: 1px solid #111;
		border-radius: 1.5rem;
		background: #fff8ee;
		box-shadow: 6px 6px 0 #111;
	}

	.vak-image {
		width: 100%;
		height: 14rem;
		object-fit: cover;
		object-position: center;
		display: block;
		border-bottom: 1px solid #111;
		background: #dfe3b4;
	}

	.vak-content {
		padding: 1.25rem;
	}

	.vak-card h2 {
		font-size: clamp(2rem, 10vw, 3rem);
		line-height: 0.95;
		margin: 0.25rem 0 0.5rem;
	}

	.vak-subtitle {
		margin: 0 0 1.5rem;
		font-weight: 700;
	}

	.summary-block {
		line-height: 1.6;
	}

	.summary-block p {
		margin-bottom: 1rem;
	}

	.info-box {
		margin-top: 1.25rem;
		padding: 1rem;
		border: 1px solid #111;
		border-radius: 1rem;
		background: #dfe3b4;
	}

	.info-box h3 {
		margin-top: 0;
		margin-bottom: 0.75rem;
	}

	.info-box ul {
		padding-left: 1.2rem;
		margin: 0;
	}

	.info-box li {
		margin-bottom: 0.6rem;
		line-height: 1.45;
	}

	@media (min-width: 800px) {
		.vak-image {
			height: 24rem;
		}

		.vak-content {
			padding: 1.75rem;
		}
	}
</style>